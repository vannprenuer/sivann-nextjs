# Copy this file to .env.local for local development, and add the same
# keys/values in Vercel -> Project Settings -> Environment Variables for
# production.

# WordPress REST API base URL. Leave unset to use built-in seed content.
NEXT_PUBLIC_WP_API_URL=https://sivann.com/wp-json

# Contact form email delivery (optional). Get a free API key at resend.com,
# verify sending from your domain, then set these. Without RESEND_API_KEY,
# the "Say Hello" form still works but only logs submissions server-side
# instead of emailing them.
RESEND_API_KEY=
CONTACT_TO_EMAIL=hallo@sivann.com
